    {{ nvm_use }}
    npm run generate-icons
    cp assets/desktop_icon.png assets/icons/icon.png


# Builds all the assets necessary for packaging into electron
[group("build")]
[macos]
electron-assets: icons mutagen

# Builds all the assets necessary for packaging into electron
[group("build")]
[linux]
electron-assets: icons mutagen

[doc("
The one-stop shop to clean, rebuild all intermediate targets from source, download all dependencies from remotes, and
prepare for a clean build. Prefix your electron build targets for ease of use, e.g. `just refresh app` or `just refresh pkg`")]
[group("build")]
refresh-assets: clean build-frontend sidecar electron-assets

# Uses electron forge to create an executable application for MacOS on Arm64. This app will not be bundled into an installer.
[group("build")]
[working-directory("frontend")]
[macos]
build-desktop-app:
    #! /usr/bin/env bash
    {{ nvm_use }}
    # Set up the environment variables for the correct version (dev or production)
    eval $(uv run builder setup-build-vars {{ MODE }} ) && npm run electron:package
    mkdir -p ../../dist/darwin-arm64
    cp -r out/Sculptor-darwin-arm64/ ../../dist/darwin-arm64

# Uses electron forge to create an executable application for MacOS on x86_64. This app will not be bundled into an installer.
[group("build")]
[macos]
build-desktop-app--x86_64:
    #!/usr/bin/env arch -x86_64 /usr/local/bin/bash -l
    {{ nvm_use }}
    set -e
    just refresh-assets
    just sidecar "cpython-3.11.13-macos-x86_64-none"
    npm install --force
    eval $(uv run builder setup-build-vars {{ MODE }} ) && npm run electron:package -- --  --platform=darwin --arch=x64
    mkdir -p ../../dist/Darwin-x86_64
    cp -r out/Sculptor-darwin-x64/ ../../dist/darwin-x86_64

# Uses electron forge to create an executable application for Linux. This app will not be bundled into an installer.
[group("build")]
[working-directory("frontend")]
[linux]
build-desktop-app:
    #! /usr/bin/env bash
    {{ nvm_use }}
    # Set up the environment variables for the correct version (dev or production)
    eval $(uv run builder setup-build-vars {{ MODE }} ) && npm run electron:package
    mkdir -p ../../dist/linux-x64
    cp -r out/Sculptor-linux-x64/ ../../dist/linux-x64

[doc("A simpler helper to unmount any Sculptor DMGs you might have mounted previously. This prevents the build step from
failing frustratingly after a long time generating artifacts but being unable to mount.")]
[group("build")]
[private]
[macos]
unmount-dmg:
    #! /usr/bin/env bash
    set +e
    hdiutil detach /Volumes/Sculptor || echo "No dmg mounted"
    set -e

[doc("""Uses electron forge to create an installable package (DMG) for MacOS (arm64).

You do NOT need to run `just app` before this, but might need to run `just refresh`.""")]
[group("build")]
[working-directory("frontend")]
[macos]
package-desktop-installer:
    #! /usr/bin/env bash
    just unmount-dmg
    {{ nvm_use }}
    # TODO: hack to make sure we don't ship with dev/testing sentry dsn
    eval $(uv run builder setup-build-vars production) && npm run electron:make
    mkdir -p ../../dist
    cp -r out/make/zip ../../dist
    cp out/make/Sculptor.dmg ../../dist
    cp out/make/Sculptor.dmg ../../dist/Sculptor-`uv run dev version | head -n 1 | cut -f2 -d" "`.dmg
    uv run builder generate-autoupdate-manifest macos arm64
    bash "../builder/validate_sculptor_dmg.sh" ../../dist/Sculptor.dmg arm64



[doc("""Uses electron forge to create an installable package (DMG) for MacOS (x86_64).

You do NOT need to run `just app` before this, but might need to run `just refresh`.""")]
[group("build")]
[macos]
package-desktop-installer-x86_64:
    #! /usr/bin/env bash
    just unmount-dmg
    {{ nvm_use }}
    bash builder/package-sculptor-x86_64.sh
    bash "builder/validate_sculptor_dmg.sh" ../dist/Sculptor-x86_64.dmg x86_64

[doc("""Uses electron forge to create an installable package (DMG) for Linux.

You do NOT need to run `just app` before this, but might need to run `just refresh`.""")]
[group("build")]
[working-directory("frontend")]
[linux]
package-desktop-installer:
    #! /usr/bin/env bash
    {{ nvm_use }}
    npm run electron:make

    # The AppImage maker includes the version in the filename;
    # this is not good because electron-updater preserves the filename,
    # so the AppImage's filename on the user's filesystem will change between versions.
    # Rename the file to remove the version.
    mv out/make/AppImage/x64/Sculptor-*.AppImage out/make/AppImage/x64/Sculptor.AppImage

    mkdir -p ../../dist
    # Note: This cp runs on Linux and the semantics are different than on Mac
    cp -r out/make/* ../../dist
    # Note that each of amd64/x64/x86_64 refer to the same thing
    uv run builder generate-autoupdate-manifest linux amd64

pkg_filename := if os() == "linux" { "AppImage/x64/Sculptor.AppImage" } else { "Sculptor.dmg" }

# -------- Release Commands --------

# Uploads Snapshots of the artifacts for a given target to the BUILD s3 bucket and location.
[group("release")]
snapshot-build-artifacts platform arch:
    uv run builder snapshot-release-artifacts -p {{platform}} -a {{arch}}

# Pull down uploaded snapshots of the artifacts from the BUILD s3 bucket and location.
[group("release")]
retrieve-release-artifacts +args="":
    uv run builder retrieve-release-artifacts {{ args }}


[doc("""Publishes the artifacts for the given build to the public s3 buckets. This detects whether we're running in
release-candidate or not, and makes the appropriate copies.""")]
[group("release")]
publish-build-artifacts:
    uv run builder publish-build-artifacts

# Releases the Images of the Control Plane for Sculptor to GHCR and S3.
[group("release")]
[working-directory("..")]
release-control-plane:
    # TODO(danver): This build-control-plane code should be moved to builder, not cli.
    uv run --project sculptor cli build-control-plane --no-update-pinned-version

# Releases the Images of the Control Plane for Sculptor to GHCR and S3 and pins it.
[group("release")]
[working-directory("..")]
release-and-pin-control-plane:
    # TODO(danver): This build-control-plane code should be moved to builder, not cli.
    uv run --project sculptor cli build-control-plane


