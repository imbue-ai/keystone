{
  "description": "Full four-model comparison across the standard repo set.",
  "repo_list_path": "examples/repos.jsonl",
  "s3_output_prefix": "s3://int8-datasets/keystone/evals/2026-03-11_cat_v8/",
  "max_concurrent": 50,
  "s3_repo_cache_prefix": "s3://int8-datasets/keystone/evals/repo-tarballs/",
  "configs": [
    {
      "name": "claude-opus",
      "keystone_config": {
        "agent_config": {
          "provider": "claude",
          "guardrail": false, "use_agents_md": true,
          "agent_in_modal": true,
          "model": "claude-opus-4-6",
          "max_budget_usd": 10.0,
          "agent_time_limit_seconds": 3600,
          "cost_poll_interval_seconds": 30
        }
      },
      "trials_per_repo": 1,
    },
    {
      "name": "claude-haiku",
      "keystone_config": {
        "agent_config": {
          "provider": "claude",
          "guardrail": false, "use_agents_md": true,
          "agent_in_modal": true,
          "model": "claude-haiku-4-5-20251001",
          "max_budget_usd": 10.0,
          "agent_time_limit_seconds": 3600,
          "cost_poll_interval_seconds": 30
        }
      },
      "trials_per_repo": 1,
    },
    {
      "name": "codex-gpt-5.3",
      "keystone_config": {
        "agent_config": {
          "provider": "codex",
          "guardrail": false, "use_agents_md": true,
          "agent_in_modal": true,
          "model": "gpt-5.3-codex",
          "max_budget_usd": 10.0,
          "agent_time_limit_seconds": 3600,
          "cost_poll_interval_seconds": 30
        }
      },
      "trials_per_repo": 1,
    },
    {
      "name": "codex-mini-gpt-5.1",
      "keystone_config": {
        "agent_config": {
          "provider": "codex",
          "guardrail": false, "use_agents_md": true,
          "agent_in_modal": true,
          "model": "gpt-5.1-codex-mini",
          "max_budget_usd": 10.0,
          "agent_time_limit_seconds": 3600,
          "cost_poll_interval_seconds": 30
        }
      },
      "trials_per_repo": 1,
    }
  ]
}
