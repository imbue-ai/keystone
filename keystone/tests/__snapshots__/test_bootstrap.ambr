# name: test_e2e_sample_projects[fullstack_project]
  dict({
    'agent': dict({
      'exit_code': 0,
      'model': '',
      'status_messages': list([
        'Exploring repository structure to identify file types and test locations.',
        'Creating Dockerfile and test runner for Python/Flask backend + Node.js frontend project.',
        'Building the Docker image to verify the setup.',
        'Fixing Dockerfile - no uv.lock file exists, switching to direct pip install.',
        'Build succeeded. Running tests now.',
      ]),
      'summary': 'Everything worked. The project is a Python Flask backend + Node.js frontend with integration tests. Key points: no uv.lock file exists so used `uv pip install` directly rather than `uv sync --locked`; the Node.js frontend tests use the built-in `node --test` runner with `--test-reporter=junit` for JUnit XML output; the frontend integration tests start the Flask server as a subprocess, so both Python (with Flask) and Node.js must be in the same container image.',
      'timed_out': False,
    }),
    'error_message': None,
    'generated_files': dict({
      'devcontainer_json': '''
        {
          "build": {
            "dockerfile": "Dockerfile",
            "context": "..",
            "options": [
              "--network=host"
            ]
          },
          "runArgs": [
            "--network=host"
          ]
        }
  
      ''',
      'dockerfile': '''
        FROM python:3.12-slim
        
        # Install system dependencies including perl and Node.js prerequisites
        RUN apt-get update && apt-get install -y \
            perl-base \
            curl \
            ca-certificates \
            && rm -rf /var/lib/apt/lists/*
        
        # Install Node.js 20 LTS
        RUN curl -fsSL https://deb.nodesource.com/setup_20.x | bash - \
            && apt-get install -y nodejs \
            && rm -rf /var/lib/apt/lists/*
        
        # Set up timestamp helper script.
        COPY ./.devcontainer/timestamp_process_output.pl /timestamp_process_output.pl
        
        # Create test artifacts directory.
        RUN mkdir -p /test_artifacts && chmod 777 /test_artifacts
        
        # Copy uv from official image.
        COPY --from=ghcr.io/astral-sh/uv:latest /uv /uvx /bin/
        
        # Very important on Modal -- without this, there is a crazy bug that means that some files do not show up in snapshots!
        # This is because Modal's snapshotting mechanism does not work correctly with symlinks.
        ENV UV_LINK_MODE=copy
        
        # Pre-create uv virtual environment and install Python dependencies.
        ENV UV_PROJECT_ENVIRONMENT=/venv
        RUN uv venv /venv && \
            uv pip install --python /venv/bin/python flask pytest
        
        # Add venv to PATH
        ENV PATH="/venv/bin:$PATH"
        
        # Copy project source files
        WORKDIR /project_src
        COPY backend/ ./backend/
        COPY frontend/ ./frontend/
        
        # Copy the test runner script last (this changes often during development)
        COPY .devcontainer/run_all_tests.sh /run_all_tests.sh
        RUN chmod +x /run_all_tests.sh
  
      ''',
      'run_all_tests_sh': '''
        #!/usr/bin/env bash
        set -euo pipefail
        
        mkdir -p /test_artifacts/junit
        
        echo "=== Running backend Python tests ==="
        cd /project_src/backend
        /timestamp_process_output.pl --logfile /test_artifacts/pytest.log \
            pytest --junitxml=/test_artifacts/junit/pytest.xml -v .
        
        echo "=== Running frontend Node.js tests ==="
        cd /project_src/frontend
        /timestamp_process_output.pl --logfile /test_artifacts/node_test.log \
            timeout 30 node --test --test-reporter=junit --test-reporter-destination=/test_artifacts/junit/node.xml
        
        echo "=== All tests completed ==="
        
        # Write final result
        cat > /test_artifacts/final_result.json <<'EOF'
        {"status": "success"}
        EOF
  
      ''',
    }),
    'success': True,
    'verification': dict({
      'error_message': None,
      'success': True,
      'test_results': list([
        dict({
          'name': 'test::add via API',
          'passed': True,
          'skipped': False,
        }),
        dict({
          'name': 'test::multiply via API',
          'passed': True,
          'skipped': False,
        }),
        dict({
          'name': 'server_test::test_server_is_running',
          'passed': True,
          'skipped': False,
        }),
        dict({
          'name': 'test_simple::test_pass',
          'passed': True,
          'skipped': False,
        }),
        dict({
          'name': 'test_simple::test_also_passes',
          'passed': True,
          'skipped': False,
        }),
      ]),
    }),
  })
