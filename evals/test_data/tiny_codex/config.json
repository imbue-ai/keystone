{
  // Manual-run config for codex (default model) on requests repo.
  // The automated test is in evals/test_tiny_codex.py (uses file:// paths via tmp_path).
  // To run manually:  cd evals && uv run eval-harness --config_file test_data/tiny_codex/config.json --no_cache_replay
  "description": "Manual smoke test for codex default model on requests repo.",
  "repo_list_path": "test_data/tiny_codex/repos.jsonl",
  "s3_output_prefix": "s3://int8-datasets/keystone/evals/test-tiny-codex/",
  "s3_repo_cache_prefix": "s3://int8-datasets/keystone/evals/repo-tarballs/",
  "configs": [
    {
      "name": "codex-default",
      "keystone_config": {
        "agent_config": {
          "provider": "codex",
          "guardrail": true, "use_agents_md": true,
          "agent_in_modal": true,
          "max_budget_usd": 5.0,
          "agent_time_limit_seconds": 1200
        }
      },
      "trials_per_repo": 1,
    }
  ]
}
