			"text": "  ActiveSync(\n    mutagen_sync_state,\n    git_sync_state,\n    # eventually:\n    flags = (\n      IS_AGENT_AUTO_REBASING_ON_CONFLICT,\n      # etc\n    )\n  ):\n    def on_reconciliation_failure(): pause()",
			"rawText": "  ActiveSync(\n    mutagen_sync_state,\n    git_sync_state,\n    # eventually:\n    flags = (\n      IS_AGENT_AUTO_REBASING_ON_CONFLICT,\n      # etc\n    )\n  ):\n    def on_reconciliation_failure(): pause()",
