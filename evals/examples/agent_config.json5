{
    // Model configuration
    "model": "claude-sonnet-4-20250514",
    "max_budget_usd": 1.0,
    
    // Git source for bootstrap_devcontainer
    // Use a pinned commit hash for reproducibility
    "bootstrap_git_url": "https://github.com/imbue-ai/bootstrap_devcontainer",
    "bootstrap_git_ref": "prod",  // or a specific commit hash like "abc123"
    
    // Execution settings
    "timeout_minutes": 30,
    
    // Cache settings
    "use_cache": true,
}
