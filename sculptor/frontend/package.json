{
  "name": "sculptor",
  "productName": "Sculptor",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": ".vite/build/main.cjs",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "vite build -l error",
    "lint-compat": "ESLINT_USE_FLAT_CONFIG=false eslint --ext js,ts,jsx,tsx,vue,cjs --report-unused-disable-directives --max-warnings 0 ",
    "tsc": "tsc --noEmit",
    "lint": "eslint --ext js,ts,jsx,tsx,vue,cjs --report-unused-disable-directives --no-warn-ignored --max-warnings 0 ",
    "preview": "vite preview",
    "format": "eslint --fix --no-warn-ignored",
    "prettier-format": "prettier --write",
    "depcheck": "depcheck --ignores=typescript,eslint,prettier,autoprefixer,postcss,tailwindcss,prettier-plugin-organize-imports",
    "rule-errors": "eslint-config-prettier src/Main.tsx",
    "freeze": "npm list --depth=0",
    "generate-api-json-schema": "uv run python ../../sculptor/sculptor/scripts/generate_json_schema.py ./sculptor_schema.json",
    "fixup-js-types": "uv run python ../../sculptor/sculptor/scripts/fixup_js_types.py ./src/api/types.gen.ts",
    "generate-api": "npm run generate-api-json-schema && npx @hey-api/openapi-ts && npm run fixup-js-types",
    "test": "jest",
    "electron:start": "cross-env SCULPTOR_FRONTEND_DIR=$PWD electron-forge start",
    "preelectron:package": "cd .. && uv run sculptor/scripts/dev.py sync-frontend-version",
    "electron:package": "electron-forge package",
    "postelectron:package": "cd .. && uv run sculptor/scripts/dev.py sync-frontend-version --reverse",
    "preelectron:make": "cd .. && uv run sculptor/scripts/dev.py sync-frontend-version",
    "electron:make": "electron-forge make",
    "postelectron:make": "cd .. && uv run sculptor/scripts/dev.py sync-frontend-version --reverse",
    "generate-icons": "mkdir -p ./assets/icons && png2icons ./assets/desktop_icon.png ./assets/icons/icon -allp"
  },
  "dependencies": {
    "@floating-ui/dom": "1.7.1",
    "@radix-ui/colors": "3.0.0",
    "@radix-ui/react-checkbox": "1.1.1",
    "@radix-ui/react-collapsible": "1.1.0",
    "@radix-ui/react-dialog": "1.1.1",
    "@radix-ui/react-hover-card": "1.1.1",
    "@radix-ui/react-icons": "1.3.0",
    "@radix-ui/react-portal": "1.1.1",
    "@radix-ui/react-progress": "1.1.0",
    "@radix-ui/react-separator": "1.1.0",
    "@radix-ui/react-switch": "1.1.1",
    "@radix-ui/react-tabs": "1.1.0",
    "@radix-ui/react-toast": "1.2.14",
    "@radix-ui/react-toggle": "1.1.0",
    "@radix-ui/react-toggle-group": "1.1.0",
    "@radix-ui/react-tooltip": "1.2.8",
    "@radix-ui/themes": "3.1.3",
    "@sentry/react": "8.25.0",
    "@sentry/tracing": "7.120.4",
    "@tiptap/extension-code-block-lowlight": "2.27.1",
    "@tiptap/extension-mention": "2.27.1",
    "@tiptap/extension-placeholder": "2.27.1",
    "@tiptap/react": "2.27.1",
    "@tiptap/starter-kit": "2.27.1",
    "@tiptap/suggestion": "2.27.1",
    "change-case": "5.4.4",
    "electron-log": "5.4.3",
    "electron-squirrel-startup": "1.0.1",
    "electron-store": "11.0.0",
    "electron-updater": "6.6.2",
    "eslint-plugin-simple-import-sort": "12.1.1",
    "get-port": "7.1.0",
    "highlight.js": "11.11.1",
    "jotai": "2.9.2",
    "jotai-effect": "1.0.3",
    "jotai-tanstack-query": "0.8.6",
    "lodash": "4.17.21",
    "lowlight": "3.3.0",
    "lucide-react": "0.468.0",
    "posthog-js": "1.255.1",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-emoji": "0.5.0",
    "react-hotkeys-hook": "4.5.0",
    "react-markdown": "10.1.0",
    "react-resizable-panels": "3.0.2",
    "react-router-dom": "6.26.0",
    "react-textarea-autosize": "8.5.9",
    "remark-emoji": "5.0.1",
    "remark-gfm": "4.0.1",
    "sass": "1.77.8",
    "tiptap-markdown": "0.8.10",
    "toml": "3.0.0",
    "typeid-js": "1.2.0",
    "uuid": "11.0.2"
  },
  "devDependencies": {
    "@babel/preset-env": "7.26.0",
    "@babel/preset-react": "7.28.5",
    "@babel/preset-typescript": "7.26.0",
    "@electron-forge/cli": "7.8.3",
    "@electron-forge/maker-deb": "7.8.3",
    "@electron-forge/maker-dmg": "7.8.3",
    "@electron-forge/maker-rpm": "7.8.3",
    "@electron-forge/maker-squirrel": "7.8.3",
    "@electron-forge/maker-zip": "7.8.3",
    "@electron-forge/plugin-auto-unpack-natives": "7.8.3",
    "@electron-forge/plugin-fuses": "7.8.3",
    "@electron-forge/plugin-vite": "7.8.3",
    "@electron/fuses": "1.8.0",
    "@eslint/js": "9.28.0",
    "@hey-api/openapi-ts": "0.80.1",
    "@reforged/maker-appimage": "5.1.0",
    "@sentry/vite-plugin": "3.5.0",
    "@stylistic/eslint-plugin": "4.4.0",
    "@stylistic/eslint-plugin-js": "4.4.0",
    "@stylistic/eslint-plugin-ts": "4.4.0",
    "@swc/cli": "0.4.0",
    "@swc/core": "1.7.26",
    "@swc/plugin-styled-components": "2.0.12",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.0",
    "@types/jest": "30.0.0",
    "@types/lodash": "4.17.7",
    "@types/react": "18.3.3",
    "@types/react-dom": "18.3.0",
    "@typescript-eslint/eslint-plugin": "8.33.1",
    "@typescript-eslint/parser": "8.33.1",
    "@vitejs/plugin-react": "5.0.0",
    "@vitejs/plugin-react-swc": "3.7.0",
    "@vitest/browser": "3.0.9",
    "@vitest/coverage-v8": "3.0.9",
    "autoprefixer": "10.4.20",
    "cross-env": "^7",
    "depcheck": "1.4.7",
    "electron": "37.2.6",
    "eslint": "9.28.0",
    "eslint-config-prettier": "10.1.5",
    "eslint-plugin-css": "0.11.0",
    "eslint-plugin-import": "2.31.0",
    "eslint-plugin-prettier": "5.4.1",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "5.2.0",
    "eslint-plugin-react-refresh": "0.4.20",
    "eslint-plugin-storybook": "9.0.4",
    "globals": "16.2.0",
    "jest": "29.7.0",
    "jest-environment-jsdom": "29.7.0",
    "patch-package": "8.0.1",
    "playwright": "1.51.1",
    "png2icons": "2.0.1",
    "postcss": "8.4.41",
    "prettier": "3.3.3",
    "ts-morph": "26.0.0",
    "ts-node": "10.9.2",
    "tsx": "4.20.6",
    "typescript": "5.5.4",
    "typescript-eslint": "8.33.1",
    "vite": "5.4.0",
    "vitest": "3.0.9"
  },
  "overrides": {
    "phantomjs-prebuilt": "file:stubs/phantomjs-prebuilt"
  },
  "config": {
    "forge": "./forge.config.ts"
  }
}
