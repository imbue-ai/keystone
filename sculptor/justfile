# Runs the dev command to create a branch bumping the version
[group("release")]
bump-version args="":
    uv run builder bump-version {{args}}

# Run the dev command to cut a release
[group("release")]
cut-release args="":
    uv run builder cut-release {{args}}

# Run the dev command to update a release
[group("release")]
fixup-release args="":
    uv run builder fixup-release {{args}}

# Begins a hotfix branch for a release that was already published
[group("release")]
hotfix-release args="":
    uv run builder hotfix-release {{args}}


# Promote a release to the latest version
[group("release")]
promote-release args="":
    uv run builder promote-release {{args}}

# Show a help message listing all the commands
help:
    @echo "Sculptor's Justfile"
    @echo "Contains commands for installing, developing, building and releasing Sculptor"
    @just --list --unsorted
