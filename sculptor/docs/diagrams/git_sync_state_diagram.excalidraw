			"link": null,
			"locked": false,
			"text": "  PausedSync(\n    mutagen_sync_state,\n    git_sync_state,\n \n  ):\n    .valid_actions ~= (\n      AUTO_RESUME, DISCARD,\n      AUTO_RECONCILE_AND_RESUME # eventually\n    )\n    def on_reconciliation_recovery(): resume()",
			"rawText": "  PausedSync(\n    mutagen_sync_state,\n    git_sync_state,\n \n  ):\n    .valid_actions ~= (\n      AUTO_RESUME, DISCARD,\n      AUTO_RECONCILE_AND_RESUME # eventually\n    )\n    def on_reconciliation_recovery(): resume()",
