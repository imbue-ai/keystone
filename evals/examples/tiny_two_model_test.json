{
  // Minimal eval: 2 cheap models × 2 repos × 2 trials
  "description": "Minimal smoke test: 2 cheap models x 2 repos x 2 trials.",
  "repo_list_path": "evals/examples/repos_tiny.jsonl",
  // Might want to do this first:
  // rm -rf /tmp/keystone-evals/tiny-test_v1
  "s3_output_prefix": "file:///tmp/keystone-evals/tiny-test_v1",
  "s3_repo_cache_prefix": "file:///tmp/keystone-evals/repo-tarballs/",
  "configs": [
    {
      "name": "claude-haiku",
      "agent_config": {
        "provider": "claude",
        "evaluator": true,
        "model": "claude-haiku-4-5-20251001",
        "max_budget_usd": 5.0,
        "timeout_minutes": 20
      },
      "trials_per_repo": 1,
    },
    {
      "name": "codex-mini",
      "agent_config": {
        "provider": "codex",
        "evaluator": true,
        "model": "gpt-5.1-codex-mini",
        "max_budget_usd": 5.0,
        "timeout_minutes": 20
      },
      "trials_per_repo": 1,
    }
  ]
}
