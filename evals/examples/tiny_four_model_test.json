{
  // Minimal eval: 4 models x 2 repos x 1 trial = 8 total tasks
  "description": "Minimal smoke test: 4 models x 2 repos x 1 trial -- trying without evalua",
  "repo_list_path": "evals/examples/repos_tiny.jsonl",
  // Might want to do this first:
  // rm -rf /tmp/keystone-evals/tiny-four-model_v1
  "s3_output_prefix": "file:///tmp/keystone-evals/tiny-four-model_v4",
  "s3_repo_cache_prefix": "file:///tmp/keystone-evals/repo-tarballs/",
  "configs": [
    {
      "name": "claude-opus",
      "keystone_config": {
        "agent_config": {
          "provider": "claude",
          "guardrail": true, "use_agents_md": true,
          "agent_in_modal": true,
          "model": "claude-opus-4-6",
          "max_budget_usd": 5.0,
          "agent_time_limit_seconds": 1200,
          "cost_poll_interval_seconds": 30
        }
      },
      "trials_per_repo": 1,
    },
    {
