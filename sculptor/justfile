default: help

# Use bash with strict flags
set shell := ["bash", "-eu", "-o", "pipefail", "-c"]
set dotenv-load := true


# -------- Defaults / Vars --------
session_name := env('SESSION_NAME', 'sculptor-session')
ENABLED_FRONTEND_ARTIFACT_VIEWS := env('ENABLED_FRONTEND_ARTIFACT_VIEWS', '')
MODE := env('MODE', '')  # lets you override --mode if desired
_ENV_SHELL := env('SHELL', '/bin/bash')
export ENVIRONMENT := env('ENVIRONMENT',  'dev')
export DEV_MODE := env('DEV_MODE', 'false')
SCULPTOR_FOLDER := env('SCULPTOR_FOLDER', '~/.sculptor')
DEV_SCULPTOR_FOLDER := '~/.dev_sculptor/'

# Reusable, embeddable snippet to ensure Node via nvm is active in THIS shell
nvm_use := '''
set +u
: "${NVM_DIR:="$HOME/.nvm"}"
. "$NVM_DIR/nvm.sh"
nvm install 20.13.1 >/dev/null
nvm use --silent 20.13.1
set -u
'''

# -------- Aliases --------
alias start := tmux-dev
alias stop := tmux-stop
alias app := build-desktop-app
alias pkg := package-desktop-installer
alias refresh := refresh-assets
alias snapshot := snapshot-build-artifacts
alias publish := publish-build-artifacts
alias promote := promote-release
alias fixup := fixup-release
alias hotfix := hotfix-release
alias rebuild-cp := rebuild-control-plane-volume


# -------- Team-specific aliases -------

# The Capabilities team usually want to rebuild the control plane volume before `just start`
[group("dev")]
start-cap: rebuild-control-plane-volume tmux-dev

# -------- Development Commands --------

# Show last 256 log lines, then follow logs in real-time
[group("dev")]
tail-logs dev="":
    # if dev mode, tail from dev sculptor folder
    tail -n 256 -F {{ if dev != "" { DEV_SCULPTOR_FOLDER } else { SCULPTOR_FOLDER } }}"/logs/server/logs.jsonl" \
      | jq -r '(.record.file.path // "") + " | " + (.text // "")' \
      | sed '/^[[:space:]]*$/d'

# Start the Electron server
[group("dev")]
[working-directory("frontend")]
frontend:
  npm run electron:start -- --  --unhandled-rejections=strict --trace-warnings

[group("dev")]
rebuild-control-plane-volume:
    cd ../ && uv run --project sculptor sculptor/sculptor/cli/dev.py build-control-plane-locally --skip-clean-check

# Start the Backend server
[group("dev")]
backend repo_path="..":
    echo "Starting backend server..."
    echo "Using repository path: {{repo_path}}"
    uv run python -m sculptor.cli.main --no-open-browser --no-serve-static {{repo_path}}

[group("dev")]
tmux-dev repo_path=".." dev_mode=DEV_MODE:
    #!/bin/bash
    just stop || true
    echo "Starting tmux development session..."
    echo "Using repository path: {{repo_path}}"
    echo "Killing existing session if present..."
    tmux kill-session -t {{session_name}} 2>/dev/null || true
    echo "Creating new tmux session..."
    tmux new-session -d -s {{session_name}} -n frontend `shell echo $$SHELL`
    tmux new-window -t {{session_name}} -e SCULPTOR_CONTROL_PLANE_VOLUME="$SCULPTOR_CONTROL_PLANE_VOLUME"  -n backend `shell echo $$SHELL`
    tmux send-keys -t {{session_name}}:frontend "env SCULPTOR_API_PORT=1224 DEV_MODE={{dev_mode}} just frontend" Enter
    tmux send-keys -t {{session_name}}:backend "env SCULPTOR_API_PORT=1224 DEV_MODE={{dev_mode}} just backend {{repo_path}}" Enter
    echo "Development servers started in tmux session '{{session_name}}'"
    echo "Backend serving repository: {{repo_path}}"
    echo "Use 'tmux attach -t {{session_name}}' to attach to the session"
    echo "Use 'just tmux-stop' to stop the session"
    tmux attach -t {{session_name}} || echo "Failed to attach to tmux session. You can attach manually using 'tmux attach -t {{session_name}}'"

tmux-stop:
	tmux kill-session -t {{session_name}} 2>/dev/null && echo "Session '{{session_name}}' terminated" || echo "Session '{{session_name}}' did not exist"

# Rebuilds everything needed to successfully `just start` after changing commits
[group("dev")]
rebuild: clean install generate-api rebuild-control-plane-volume


# run type checking via ty
[group("dev")]
ty-check args="":
    #!/usr/bin/env bash
    uv run ty check {{args}}

# -------- Build Commands --------

# Cleans up all files generated by the build process
[group("build")]
clean:
    @echo "Cleaning up..."
    rm -rf frontend/node_modules
    rm -rf frontend/package-lock.json
    rm -rf sculptor/web/frontend
    find . -type d -name "__pycache__" -exec rm -rf {} + 2>/dev/null || true
    find . -name "*.pyc" -delete 2>/dev/null || true

    # clean control plane state
    rm sculptor/primitives/hashes/control_plane_local_tag.txt || true

    rm claude-container/*.whl || true
    rm -r ./frontend-dist/* || true
    rm -r ./frontend/dist/* || true
    rm -r build/* || true
    rm -r _vendor/* || true
    rm -r _vendor/.lock || true
    rm sculptor/_version.py || true
    rm -rf frontend/src/api || true
    rm -rf frontend/out || true
    rm -rf frontend/.vite || true
    rm -rf ./dist/* || true
    rm -rf ../dist/* || true

# Installs build dependencies for a Mac
[group("install")]
[macos]
install-build-deps:
    #! /usr/bin/env bash
    echo "Installing platform-specific build dependencies"
    # Qi: the uv python commands shouldn't be necessary most of the time,
    # but Danver told me these are macOS x64 builds to function correctly -
    # we have a weird setup there where some workflows are run with arm mode and some with x64 mode.
    uv python install 3.11
    uv python update-shell
    brew install depot/tap/depot
    {{ nvm_use }}

# Generates the frontend type definitions based on the API
[group("build")]
[working-directory("frontend")]
generate-api:
    #! /usr/bin/env bash
    {{ nvm_use }}
    npm run generate-api

# Installs all frontend libraries necessary
[group("install")]
[working-directory("frontend")]
install-frontend: && generate-api
    #! /usr/bin/env bash
    {{ nvm_use }}
    echo "Installing frontend dependencies..."
    npm install --force

# Installs all backend dependencies
[group("install")]
install-backend:
    # We don't actually have any pre-build installations for the backend now,
    # but leaving it as a no-op in case we need it in the future.

# Installs optional build dependencies for a Mac
[group("install")]
[macos]
install-build-deps-x86_64:
    bash builder/install-build-dependencies-x86_64.sh

# Installs build dependencies
[group("install")]
[linux]
install-build-deps:
    #! /usr/bin/env bash
    echo "Installing platform-specific build dependencies"
    uv python install 3.11
    uv python update-shell
    curl -L https://depot.dev/install-cli.sh | sh -s
    {{ nvm_use }}

# Installs all dependencies.
[group("install")]
install: install-build-deps install-backend install-frontend

# Installs additional dependencies for testing
[group("install")]
install-test:
	uv run -m playwright install --with-deps


# Creates a FE distribution for the backend to serve statically
[group("build")]
build-frontend: install-frontend
    #! /usr/bin/env bash
    {{ nvm_use }}
    # TODO: not calling setup-build-vars because we'll pelt sentry in tests
    cd frontend && npm run build --mode {{MODE}}
    mkdir -p ./frontend-dist
    cp -a dist/. ../frontend-dist/

[group("build")]
build-backend: install-backend
    @echo "Creating an sdist for sculptor"
    uv run builder create-version-file

# Build the control plane for local iteration
[group("build")]
build-local-control-plane:
    #!/usr/bin/env bash
    set -euo pipefail
    : ${SCULPTOR_CONTROL_PLANE_VOLUME:?Error: SCULPTOR_CONTROL_PLANE_VOLUME must be set}
    uv run sculptor/scripts/dev.py rebuild_container_for_local_testing "$SCULPTOR_CONTROL_PLANE_VOLUME"


# Clean the control plane for local iteration
[group("build")]
clean-local-control-plane:
    #!/usr/bin/env bash
    set -euo pipefail
    : ${SCULPTOR_CONTROL_PLANE_VOLUME:?Error: SCULPTOR_CONTROL_PLANE_VOLUME must be set}
    docker volume rm -f "$SCULPTOR_CONTROL_PLANE_VOLUME"

# Builds the Sculptor webapp in the default environment.
[group("build")]
build: (pyre-check) build-frontend build-backend

# run pyre type checking. can be skipped with by setting env var SKIP_PYRE_IN_SCULPTOR_BUILD=1
[private]
pyre-check:
    #!/usr/bin/env bash
    set -euo pipefail
    if [ -n "${SKIP_PYRE_IN_SCULPTOR_BUILD:-}" ]; then
        echo "Skipping pyre check (SKIP_PYRE_IN_SCULPTOR_BUILD is set)"
    else
        echo "Running pyre type check..."
        uv run pyre
        echo "Pyre check passed!"
    fi

# Creates a production build of the Sculptor webapp and backend.
[group("build")]
dist:
    # The ENVIRONMENT variable gets eventually passed to sculptor/builder/cli.py,
    # where it's used to derive environment variables defining sentry DSN and release ID,
    # which then get picked up as Vite defines and affect the built JS files.
    #
    # TODO(Qi): Look into if there are cleaner and simpler alternatives.
    # In particular, it feels wrong to have build-time environment variables affecting runtime behavior in this way.
    @just ENVIRONMENT=production build-frontend build-backend

# Builds a "sidecar" of the Sculptor webapp backend.
[group("build")]
sidecar python_key="": dist
    /usr/bin/env bash builder/build-sidecar.sh {{ python_key }}

# Downloads the appropriate mutagen for your current environment
[group("build")]
[private]
mutagen:
    ./download_mutagen

